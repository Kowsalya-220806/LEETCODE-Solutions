class Solution {
public:
    vector<vector<int>> threeSum(vector<int>& nums) {
        vector<vector<int>> result;
        int n = nums.size();
        
        // 1. Sort the array to use two pointers and skip duplicates
        sort(nums.begin(), nums.end());

        for (int i = 0; i < n - 2; ++i) {
            // Skip the same element for the first position to avoid duplicates
            if (i > 0 && nums[i] == nums[i - 1]) continue;

            // Optimization: If the smallest possible sum is > 0, no need to continue
            if (nums[i] + nums[i+1] + nums[i+2] > 0) break;
            // Optimization: If the current number + two largest numbers < 0, check next i
            if (nums[i] + nums[n-2] + nums[n-1] < 0) continue;

            int left = i + 1;
            int right = n - 1;

            while (left < right) {
                int sum = nums[i] + nums[left] + nums[right];

                if (sum == 0) {
                    result.push_back({nums[i], nums[left], nums[right]});
                    
                    // Skip duplicates for the second and third positions
                    while (left < right && nums[left] == nums[left + 1]) left++;
                    while (left < right && nums[right] == nums[right - 1]) right--;
                    
                    left++;
                    right--;
                } else if (sum < 0) {
                    left++; // Need a larger sum
                } else {
                    right--; // Need a smaller sum
                }
            }
        }
        return result;
    }
};

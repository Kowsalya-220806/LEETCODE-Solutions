class Solution {
public:
    ListNode* rotateRight(ListNode* head, int k) {
        // Base cases: empty list, single node, or no rotation
        if (!head || !head->next || k == 0) return head;

        // 1. Find the length and the current tail node
        ListNode* tail = head;
        int n = 1;
        while (tail->next) {
            tail = tail->next;
            n++;
        }

        // 2. Adjust k and handle cases where k is a multiple of n
        k = k % n;
        if (k == 0) return head;

        // 3. Connect tail to head to make it circular
        tail->next = head;

        // 4. Find the new tail: it's at position (n - k - 1) from the start
        ListNode* new_tail = head;
        for (int i = 0; i < n - k - 1; i++) {
            new_tail = new_tail->next;
        }

        // 5. The new head is the node after the new tail
        ListNode* new_head = new_tail->next;
        new_tail->next = nullptr; // Break the ring

        return new_head;
    }
};

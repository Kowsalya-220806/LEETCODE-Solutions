#include <string>
#include <vector>
#include <algorithm>
using namespace std;
class Solution {
public:
    string shortestPalindrome(string s) {
        if (s.empty()) return s;
        string rev_s = s;
        reverse(rev_s.begin(), rev_s.end());
        string temp = s + "#" + rev_s;
        int n = temp.size();
        vector<int> lps(n, 0);
        for (int i = 1; i < n; i++) {
            int j = lps[i - 1];
            while (j > 0 && temp[i] != temp[j]) {
                j = lps[j - 1];
            }
            if (temp[i] == temp[j]) {
                j++;
            }
            lps[i] = j;
        }
      
        int longest_pal_len = lps.back();
        
        string to_add = rev_s.substr(0, s.size() - longest_pal_len);
        return to_add + s;
    }
};

class Solution {
public:
    void traverse(TreeNode* node, vector<int>& result) {
        if (!node) return;
        
        traverse(node->left, result);  // Left
        result.push_back(node->val);   // Root
        traverse(node->right, result); // Right
    }

    vector<int> inorderTraversal(TreeNode* root) {
        vector<int> result;
        traverse(root, result);
        return result;
    }
};

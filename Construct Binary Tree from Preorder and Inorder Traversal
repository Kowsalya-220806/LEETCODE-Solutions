class Solution {
public:
    int preIdx = 0;
    unordered_map<int, int> inMap;

    TreeNode* build(vector<int>& preorder, int left, int right) {
        // Base case: no elements to form a subtree
        if (left > right) return nullptr;

        // 1. Pick the current root from preorder using preIdx
        int rootVal = preorder[preIdx++];
        TreeNode* root = new TreeNode(rootVal);

        // 2. Find the index of this root in the inorder array
        int mid = inMap[rootVal];

        // 3. Recursively build the left and right subtrees
        // Important: Build the LEFT subtree first because preorder is (Root -> Left -> Right)
        root->left = build(preorder, left, mid - 1);
        root->right = build(preorder, mid + 1, right);

        return root;
    }

    TreeNode* buildTree(vector<int>& preorder, vector<int>& inorder) {
        // Map each value to its index for O(1) lookup
        for (int i = 0; i < inorder.size(); ++i) {
            inMap[inorder[i]] = i;
        }
        
        return build(preorder, 0, inorder.size() - 1);
    }
};

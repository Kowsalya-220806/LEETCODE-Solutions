class Solution {
public:
    vector<vector<int>> subsets(vector<int>& nums) {
        vector<vector<int>> result = {{}}; // Start with the empty set
        
        for (int num : nums) {
            int n = result.size();
            for (int i = 0; i < n; i++) {
                // Take existing subsets and add the current number
                vector<int> nextSubset = result[i];
                nextSubset.push_back(num);
                result.push_back(nextSubset);
            }
        }
        
        return result;
    }
};

class Solution {
public:
    string largestNumber(vector<int>& nums) {
        vector<string> arr;
        for (int num : nums) {
            arr.push_back(to_string(num));
        }

        // Custom sort: compare concatenated versions
        sort(arr.begin(), arr.end(), [](string &a, string &b) {
            return a + b > b + a;
        });

        // Handle the case where the largest number is "0"
        if (arr[0] == "0") {
            return "0";
        }

        string result = "";
        for (string &s : arr) {
            result += s;
        }

        return result;
    }
};

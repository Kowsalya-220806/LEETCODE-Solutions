#include <string>
#include <vector>
#include <numeric>
using namespace std;
class Solution {
public:
    int calculate(string s) {
        int n = s.length();
        if (n == 0) return 0;
        vector<int> stack;
        long currNum = 0;
        char op = '+';
        for (int i = 0; i < n; i++) {
            char c = s[i];
            if (isdigit(c)) {
                currNum = currNum * 10 + (c - '0');
            }
            if ((!isdigit(c) && !isspace(c)) || i == n - 1) {
                if (op == '+') {
                    stack.push_back(currNum);
                } else if (op == '-') {
                    stack.push_back(-currNum);
                } else if (op == '*') {
                    int top = stack.back();
                    stack.pop_back();
                    stack.push_back(top * currNum);
                } else if (op == '/') {
                    int top = stack.back();
                    stack.pop_back();
                    stack.push_back(top / currNum);
                }
                op = c;
                currNum = 0;
            }
        }

        int result = 0;
        for (int val : stack) {
            result += val;
        }
        return result;
    }
};

#include <vector>
#include <algorithm>

using namespace std;

class Solution {
public:
    vector<vector<int>> subsetsWithDup(vector<int>& nums) {
        vector<vector<int>> result;
        vector<int> currentPath;
        
        // 1. Sort to handle duplicates
        sort(nums.begin(), nums.end());
        
        backtrack(nums, 0, currentPath, result);
        return result;
    }

private:
    void backtrack(vector<int>& nums, int start, vector<int>& path, vector<vector<int>>& result) {
        // 2. Add current subset to result
        result.push_back(path);
        
        for (int i = start; i < nums.size(); i++) {
            // 3. Skip duplicates: if current element is same as previous
            // and we are NOT at the beginning of this recursive call
            if (i > start && nums[i] == nums[i - 1]) {
                continue;
            }
            
            // 4. Choose the element
            path.push_back(nums[i]);
            
            // 5. Explore further (start from i + 1)
            backtrack(nums, i + 1, path, result);
            
            // 6. Backtrack: remove the element to try others
            path.pop_back();
        }
    }
};

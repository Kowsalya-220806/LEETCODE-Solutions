class Solution {
public:
    int findPeakElement(vector<int>& nums) {
        int left = 0;
        int right = nums.size() - 1;

        while (left < right) {
            int mid = left + (right - left) / 2;

            if (nums[mid] < nums[mid + 1]) {
                // We are on an upward slope, peak is to the right
                left = mid + 1;
            } else {
                // We are on a downward slope, peak is mid or to the left
                right = mid;
            }
        }

        // Left and right will meet at a peak element
        return left;
    }
};

class Solution {
public:
    void backtrack(int start, vector<int>& nums, vector<vector<int>>& res) {
        // Base case: If we've fixed all positions, add the current permutation
        if (start == nums.size()) {
            res.push_back(nums);
            return;
        }

        for (int i = start; i < nums.size(); i++) {
            // Swap the current index with the element at i to "fix" it
            swap(nums[start], nums[i]);
            
            // Recurse to fix the next position
            backtrack(start + 1, nums, res);
            
            // Backtrack: Swap back to restore the original state for the next iteration
            swap(nums[start], nums[i]);
        }
    }

    vector<vector<int>> permute(vector<int>& nums) {
        vector<vector<int>> res;
        backtrack(0, nums, res);
        return res;
    }
};

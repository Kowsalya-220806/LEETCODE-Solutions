class Solution {
public:
    ListNode* reverseBetween(ListNode* head, int left, int right) {
        if (!head || left == right) return head;

        // Dummy node to simplify cases where left = 1
        ListNode* dummy = new ListNode(0, head);
        ListNode* pre = dummy;

        // 1. Reach the node just before the 'left' position
        for (int i = 0; i < left - 1; ++i) {
            pre = pre->next;
        }

        // 2. Reverse the sub-list using the 'bridging' technique
        // curr is the node that will eventually be at the end of the reversed section
        ListNode* curr = pre->next; 
        for (int i = 0; i < right - left; ++i) {
            ListNode* temp = curr->next;
            curr->next = temp->next;
            temp->next = pre->next;
            pre->next = temp;
        }

        return dummy->next;
    }
};

class Solution {
public:
    int removeDuplicates(vector<int>& nums) {
        int n = nums.size();
        if (n <= 2) return n; // If size is 0, 1, or 2, no need to remove anything
        
        int k = 2; // Start writing from the third element
        for (int i = 2; i < n; i++) {
            // If current element is different from the element 2 positions back
            // in the 'new' array, it's valid (appears at most twice).
            if (nums[i] != nums[k - 2]) {
                nums[k] = nums[i];
                k++;
            }
        }
        
        return k;
    }
};

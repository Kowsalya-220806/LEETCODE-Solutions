class Solution {
public:
    void backtrack(vector<int>& candidates, int target, int start, vector<int>& path, vector<vector<int>>& res) {
        if (target == 0) {
            res.push_back(path);
            return;
        }

        for (int i = start; i < candidates.size(); i++) {
            // Optimization: If the current number is greater than the target, 
            // no need to check this or any subsequent numbers (since sorted).
            if (candidates[i] > target) break;

            // Skip duplicate elements to avoid duplicate combinations
            if (i > start && candidates[i] == candidates[i - 1]) continue;

            path.push_back(candidates[i]);
            // Move to i + 1 because each number can be used only once
            backtrack(candidates, target - candidates[i], i + 1, path, res);
            path.pop_back(); // Backtrack
        }
    }

    vector<vector<int>> combinationSum2(vector<int>& candidates, int target) {
        sort(candidates.begin(), candidates.end());
        vector<vector<int>> res;
        vector<int> path;
        backtrack(candidates, target, 0, path, res);
        return res;
    }
};

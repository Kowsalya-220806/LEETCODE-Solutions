class Solution {
public:
    vector<int> plusOne(vector<int>& digits) {
        int n = digits.size();
        
        // Start from the last digit (least significant)
        for (int i = n - 1; i >= 0; i--) {
            if (digits[i] < 9) {
                // If current digit is less than 9, just increment and return
                digits[i]++;
                return digits;
            }
            // If digit is 9, it becomes 0 and the loop continues (carry)
            digits[i] = 0;
        }
        
        // If the loop finishes, it means all digits were 9 (e.g., 999 -> 000)
        // We need to add a leading 1 (e.g., 1000)
        digits.insert(digits.begin(), 1);
        
        return digits;
    }
};

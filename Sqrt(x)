class Solution {
public:
    int mySqrt(int x) {
        if (x < 2) return x; // Handle 0 and 1

        int low = 1, high = x / 2; // Sqrt of x is never more than x/2 for x >= 2
        int ans = 0;

        while (low <= high) {
            int mid = low + (high - low) / 2;
            
            // Use division to check (mid <= x / mid) instead of (mid * mid <= x)
            // This prevents integer overflow for large values of x
            if (mid <= x / mid) {
                ans = mid;     // Potential answer found
                low = mid + 1; // Look for a larger value
            } else {
                high = mid - 1; // Too large, search lower half
            }
        }

        return ans;
    }
};

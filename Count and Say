class Solution {
public:
    string countAndSay(int n) {
        if (n <= 0) return "";
        string res = "1";
        
        // Build the sequence up to n
        for (int i = 1; i < n; i++) {
            string next_res = "";
            int count = 1;
            
            // Traverse the current string to generate the next one
            for (int j = 0; j < res.length(); j++) {
                // If the next character is the same, increment the count
                if (j + 1 < res.length() && res[j] == res[j+1]) {
                    count++;
                } else {
                    // Otherwise, append count and digit, then reset count
                    next_res += to_string(count) + res[j];
                    count = 1;
                }
            }
            res = next_res;
        }
        
        return res;
    }
};

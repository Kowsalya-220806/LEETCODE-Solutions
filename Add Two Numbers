class Solution {
public:
    ListNode* addTwoNumbers(ListNode* l1, ListNode* l2) {
        ListNode dummy(0); // Dummy node to simplify head management
        ListNode* curr = &dummy;
        int carry = 0;

        while (l1 != nullptr || l2 != nullptr || carry != 0) {
            // Get values from nodes, or 0 if we reached the end of a list
            int val1 = (l1 != nullptr) ? l1->val : 0;
            int val2 = (l2 != nullptr) ? l2->val : 0;

            // Calculate sum and update carry
            int sum = val1 + val2 + carry;
            carry = sum / 10;
            
            // Create new node with the single digit result
            curr->next = new ListNode(sum % 10);
            curr = curr->next;

            // Advance pointers if possible
            if (l1 != nullptr) l1 = l1->next;
            if (l2 != nullptr) l2 = l2->next;
        }

        return dummy.next;
    }
};

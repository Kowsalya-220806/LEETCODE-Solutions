class Solution {
public:
    int majorityElement(vector<int>& nums) {
        int candidate = 0;
        int count = 0;

        for (int num : nums) {
            // If count is 0, we pick a new potential candidate
            if (count == 0) {
                candidate = num;
            }

            // Increment if it's the candidate, decrement otherwise
            if (num == candidate) {
                count++;
            } else {
                count--;
            }
        }

        return candidate;
    }
};
